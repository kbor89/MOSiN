  FormBox[
   RowBox[{"m", "[", "k", "]"}], TraditionalForm]],ExpressionUUID->
  "1e738d49-6f1a-4762-b8a3-98ad55f6add8"],
 " - masy ci\:0119\:017cark\[OAcute]w,\n\t",
