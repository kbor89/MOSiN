Cell[TextData[{
 "Wyznaczymy lewe strony r\[OAcute]wna\:0144 \
Eulera-Lagrange\[CloseCurlyQuote]a\n",
 StyleBox[Cell[BoxData[
  FormBox[
   RowBox[{"\t\t", 
    RowBox[{
     StyleBox[
      RowBox[{
       RowBox[{
        FractionBox["\[DifferentialD]", 
         RowBox[{"\[DifferentialD]", "t"}]], 
        RowBox[{"(", 
         FractionBox[
          RowBox[{"\[PartialD]", "L"}], 
          RowBox[{"\[PartialD]", 
           StyleBox[
