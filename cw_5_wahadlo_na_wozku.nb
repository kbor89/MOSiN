Cell[TextData[{
 "Rozwa\:017camy odwr\[OAcute]cone wahad\[LSlash]o o wielu stopniach swobody \
umieszczone na w\[OAcute]zku przedstawione na rysunku. Zak\[LSlash]adamy, \
\:017ce ramiona wahad\[LSlash]a s\:0105 sztywne, pomijamy jednak ich masy. \
Przyjmujemy\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"l", "[", "k", "]"}], TraditionalForm]],ExpressionUUID->
  "9279323b-d39f-4587-8f82-01d188f88442"],
 " - d\[LSlash]ugo\:015bci ramion,\n\t",
