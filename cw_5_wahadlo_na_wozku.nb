  FormBox[
   RowBox[{"m", "[", "0", "]"}], TraditionalForm]],ExpressionUUID->
  "102622f8-0d9b-461a-a1f1-8920be725dcd"],
 " - masa w\[OAcute]zka,\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CurlyPhi]", "[", "k", "]"}], "[", "t", "]"}], 
   TraditionalForm]],ExpressionUUID->"ff1b6dd9-34a1-4564-8f41-0ab54e265528"],
 " - k\:0105ty pomi\:0119dzy ramionami wahad\[LSlash]a o osi\:0105 Y (zmienne \
uog\[OAcute]lnione),\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "[", "t", "]"}], TraditionalForm]],ExpressionUUID->
  "b39cf21b-cf76-4896-9d4b-da2cce059be8"],
 " - po\[LSlash]o\:017cenie w\[OAcute]zka,\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", ",", "w"}], TraditionalForm]],ExpressionUUID->
  "bc050ea6-dcbd-4ab3-b505-02305bb300d5"],
 " - wymiary w\[OAcute]zka,\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "f7e81665-fcf4-4c35-838a-13e111b17f1b"],
 " - si\[LSlash]a dzia\[LSlash]aj\:0105ca na w\[OAcute]zek skierowana wzd\
\[LSlash]u\:017c osi X."
}], "Text",
