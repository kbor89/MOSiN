  FormBox[
   RowBox[{
    SubscriptBox["P", "k"], "=", 
    RowBox[{
     SubscriptBox["P", 
      RowBox[{"k", "-", "1"}]], "+", 
     RowBox[{
      SubscriptBox["l", "k"], "(", " ", 
