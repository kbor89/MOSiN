10c37b2203cd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Protect", "[", 
   RowBox[{
   "P", ",", "l", ",", "\[CurlyPhi]", ",", "m", ",", "V", ",", "k", ",", 
    "f"}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.691656606875*^9, 3.6916566339375*^9}, {
   3.691928325125*^9, 3.691928325234375*^9}, 3.8261919299101043`*^9, 
   3.9840334346231256`*^9},ExpressionUUID->"e7cb3837-2b08-4564-917e-\
2f5ed0e05c8b"],

Cell[TextData[{
 "Energia kinetyczna\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "k"], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox["m", "0"], 
      RowBox[{"x", "'"}], 
      SuperscriptBox[
       RowBox[{"(", "t", ")"}], "2"]}], "+", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"k", "=", "1"}], "n"], 
       RowBox[{
        SubscriptBox["m", "k"], 
        SuperscriptBox[
         SubscriptBox["V", "k"], "2"]}]}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c73eabab-facb-4744-ada2-aeefb0e79c17"]
}], "Text",
 CellChangeTimes->{{3.8261921647100687`*^9, 3.8261921738350554`*^9}, {
  3.984031077536517*^9, 3.984031111502981*^9}, {3.9840311912837086`*^9, 
  3.984031512295484*^9}},ExpressionUUID->"072e12b3-74c4-419e-9210-\
feba8f0c5235"],

Cell[TextData[{
 "Energia potencjalna\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "p"], "=", " ", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"k", "=", "1"}], "n"], 
     RowBox[{
      SubscriptBox["m", "k"], "g", " ", 
      SubscriptBox["y", "k"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1afb6dec-b89f-4a59-a225-b8c5fb569f9e"]
}], "Text",
 CellChangeTimes->{{3.826192258086106*^9, 3.8261922641798563`*^9}, {
  3.9840315301181636`*^9, 3.9840315723463235`*^9}, {3.984031609611486*^9, 
